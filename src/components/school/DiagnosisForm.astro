---
/** 多軸フィルタ診断（<school-filter>カスタム要素・vanilla JS）。
 *  M-1対応: 状態はURLSearchParams（enumホワイトリスト照合）・DOM操作はclassList/textContentのみ。
 *  JS無効時は全カードが見える（プログレッシブ・エンハンスメント）。
 *  lock: セグメントページで既に確定している軸はUIに出さず条件として自動適用
 *  （例: 転職ページで「目的」を再度聞かない）。 */
import { GENRE } from '../../lib/schools';

interface Props {
  /** 固定する軸（例: { p: 'tenshoku' } / { k: 'kyufu' }）。該当selectは描画されない */
  lock?: Record<string, string>;
}
const { lock = {} } = Astro.props;
---
<school-filter id="shindan" class="diag" data-all={GENRE.basePath} data-lock={JSON.stringify(lock)}>
  <div class="diag-head">あなたに合うスクールをしぼり込む</div>
  <form class="diag-form">
    {!lock.p && (
      <label>目的
        <select name="p">
          <option value="">指定なし</option>
          <option value="tenshoku">AI転職</option>
          <option value="fukugyo">副業・業務活用</option>
          <option value="dx">社内DX・スキルアップ</option>
          <option value="reskilling">リスキリング（学び直し）</option>
        </select>
      </label>
    )}
    <label>予算
      <select name="b">
        <option value="">指定なし</option>
        <option value="m2">月1〜2万円台で始めたい</option>
        <option value="t5">総額5万円以内</option>
        <option value="sub">給付金・補助金を使いたい</option>
      </select>
    </label>
    <label>受講形式
      <select name="f">
        <option value="">指定なし</option>
        <option value="subscription">動画で自分のペース</option>
        <option value="banso">講師の伴走つき</option>
        <option value="community">コミュニティ型</option>
        <option value="taimen">教室（対面）</option>
      </select>
    </label>
    {!lock.k && (
      <label>こだわり
        <select name="k">
          <option value="">指定なし</option>
          <option value="kyufu">給付金対象</option>
          <option value="shikaku">資格をとりたい</option>
          <option value="kaihatsu">開発まで学びたい</option>
        </select>
      </label>
    )}
    <div class="diag-actions">
      <button type="submit" class="aff-btn diag-btn">この条件でしぼり込む</button>
      <button type="reset" class="diag-reset">リセット</button>
    </div>
  </form>
  <p class="diag-result" aria-live="polite"></p>
</school-filter>

<script>
  const ENUM: Record<string, string[]> = {
    p: ['tenshoku', 'fukugyo', 'dx', 'reskilling'],
    b: ['m2', 't5', 'sub'],
    f: ['subscription', 'banso', 'community', 'taimen'],
    k: ['kyufu', 'shikaku', 'kaihatsu'],
  };

  class SchoolFilter extends HTMLElement {
    form!: HTMLFormElement;
    result!: HTMLElement;

    connectedCallback() {
      this.form = this.querySelector('form')!;
      this.result = this.querySelector('.diag-result')!;
      this.form.addEventListener('submit', (e) => { e.preventDefault(); this.apply(true); });
      this.form.addEventListener('change', () => this.apply(false));
      this.form.addEventListener('reset', () => setTimeout(() => this.apply(false), 0));
      this.restore();
    }

    /** URL→フォーム復元（ホワイトリスト外の値は無視: M-1） */
    restore() {
      const q = new URLSearchParams(location.search);
      let any = false;
      for (const key of Object.keys(ENUM)) {
        const v = q.get(key) ?? '';
        const el = this.form.elements.namedItem(key) as HTMLSelectElement | null;
        if (v && el && ENUM[key].includes(v)) {
          el.value = v;
          any = true;
        }
      }
      if (any) this.apply(false);
    }

    state(): Record<string, string> {
      const st: Record<string, string> = {};
      // セグメントページで固定された軸（UIに出さず常時適用・ENUM照合はここでも実施）
      try {
        const lock = JSON.parse(this.dataset.lock || '{}');
        for (const [k, v] of Object.entries(lock)) {
          if (ENUM[k]?.includes(v as string)) st[k] = v as string;
        }
      } catch { /* lockなし */ }
      for (const key of Object.keys(ENUM)) {
        const el = this.form.elements.namedItem(key) as HTMLSelectElement | null;
        if (!el) continue;
        const v = el.value;
        if (v && ENUM[key].includes(v)) st[key] = v;
      }
      return st;
    }

    /** 一致した条件数を返す（0件時の近似マッチ表示に使う） */
    matchInfo(card: HTMLElement, st: Record<string, string>): { ok: number; total: number } {
      const c: boolean[] = [];
      if (st.p) c.push((card.dataset.purpose || '').split(' ').includes(st.p));
      if (st.f) c.push((card.dataset.format || '').split(' ').includes(st.f));
      if (st.k) c.push((card.dataset.kodawari || '').split(' ').includes(st.k));
      if (st.b) {
        const monthly = parseInt(card.dataset.monthly || '', 10);
        const total = parseInt(card.dataset.total || '', 10);
        const subsidy = card.dataset.subsidy || 'none';
        if (st.b === 'm2') c.push(Number.isFinite(monthly) && monthly <= 29999);
        if (st.b === 't5') c.push(Number.isFinite(total) && total <= 50000);
        if (st.b === 'sub') c.push(subsidy !== 'none');
      }
      return { ok: c.filter(Boolean).length, total: c.length };
    }

    apply(push: boolean) {
      const st = this.state();
      const cards = Array.from(document.querySelectorAll<HTMLElement>('.school-card'));
      const infos = cards.map((c) => ({ c, ...this.matchInfo(c, st), score: parseFloat(c.dataset.score || '0') }));
      const full = infos.filter((x) => x.total > 0 && x.ok === x.total);
      const active = Object.keys(st).length > 0;
      cards.forEach((c) => c.classList.remove('is-reco'));

      if (!active) {
        cards.forEach((c) => c.classList.remove('is-hidden'));
        this.result.textContent = '';
      } else if (full.length > 0) {
        infos.forEach((x) => x.c.classList.toggle('is-hidden', !(x.ok === x.total)));
        const best = full.slice().sort((a, b) => b.score - a.score)[0].c;
        best.classList.add('is-reco');
        const name = best.querySelector('.sc-name')?.textContent?.trim() ?? '';
        this.result.textContent = `${full.length}校が該当。編集部評価がもっとも高いのは「${name}」です（下に絞り込み表示中）`;
        // 「しぼり込む」押下時は結果の先頭カードまで必ず運ぶ
        if (push) best.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        // 全条件一致ゼロでも行き止まりにしない: 最も条件に近い学校を必ず表示（誠実に一致数を明示）
        const maxOk = Math.max(...infos.map((x) => x.ok));
        const near = infos.filter((x) => x.ok === maxOk && maxOk > 0)
          .sort((a, b) => b.score - a.score);
        if (near.length > 0) {
          infos.forEach((x) => x.c.classList.toggle('is-hidden', !(x.ok === maxOk)));
          near[0].c.classList.add('is-reco');
          const name = near[0].c.querySelector('.sc-name')?.textContent?.trim() ?? '';
          this.result.textContent = `全条件に一致する学校はありませんでした。いちばん近い${near.length}校（${maxOk}/${near[0].total}条件一致）を表示中。編集部評価が高いのは「${name}」です`;
          if (push) near[0].c.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          cards.forEach((c) => c.classList.add('is-hidden'));
          this.result.textContent = '条件に合うスクールがありませんでした。条件を1つ減らしてみてください。';
        }
        // 一部カードしか載っていないページ（広告LP等）では、同じ条件のまま全校一覧へ逃がす
        const all = this.dataset.all || '';
        if (all && location.pathname.replace(/\/$/, '') !== all) {
          const q = new URLSearchParams();
          for (const [k, v] of Object.entries(st)) q.set(k, v);
          const a = document.createElement('a');
          a.href = q.toString() ? `${all}?${q}` : all;
          a.textContent = 'すべてのスクールからこの条件で探す ›';
          a.style.fontWeight = '700';
          this.result.append(document.createElement('br'), a);
        }
      }
      // URL同期（M-1: 値はENUM通過済みのみ）
      const q = new URLSearchParams();
      for (const [k, v] of Object.entries(st)) q.set(k, v);
      const url = q.toString() ? `${location.pathname}?${q}` : location.pathname;
      if (push) history.pushState(null, '', url);
      else history.replaceState(null, '', url);
    }
  }
  if (!customElements.get('school-filter')) customElements.define('school-filter', SchoolFilter);
</script>
