---
/** H-2: 実質価格を主表示にしない原則を守りつつ、給付金の落差を主役級に見せる
 *  「価格インパクトパネル」（CRO監査C-1）。総額は取り消し線で併記し、
 *  条件注記(pr-cond)は必ず同一パネル内・実質額の直下に近接表示（M-2）。
 *  verified:falseの注意はスキーマ駆動で強制描画（H-6）。 */
import type { SchoolT } from '../../lib/schools';
import { yen } from '../../lib/schools';
import { simulate, SCHEME_LABEL } from '../../lib/subsidy';

interface Props { school: SchoolT }
const { school: s } = Astro.props;
const sim = s.subsidy.type !== 'none' && s.subsidy.baseFee
  ? simulate(s.subsidy.baseFee, s.subsidy.type)
  : null;
---
<div class="sc-price">
  <div class="pr-rows">
    {s.budget.monthly != null && <div class="pr-row"><span>月額</span><b>{yen(s.budget.monthly)}</b></div>}
    {s.budget.total != null && <div class="pr-row"><span>総額</span><b>{yen(s.budget.total)}</b></div>}
    <div class="pr-row"><span>期間</span><b>{s.budget.period}</b></div>
  </div>
  <p class="pr-note-s">{s.budget.note}</p>
  {s.subsidy.type !== 'none' ? (
    <div class="pr-subsidy">
      {sim ? (
        <>
          <span class="ps-label">給付金で実質</span>
          <div class="ps-price">
            <s class="ps-was">{yen(sim.fee)}</s>
            <span class="ps-arrow">→</span>
            <b class="ps-eff">{yen(sim.effective)}<small>程度</small></b>
          </div>
          <div class="ps-scheme">{SCHEME_LABEL[s.subsidy.type]}・条件をすべて満たした場合</div>
        </>
      ) : (
        <div class="ps-scheme"><b>{SCHEME_LABEL[s.subsidy.type]}</b>の対象講座あり（料金・対象はコースにより異なります）</div>
      )}
      <p class="pr-cond">{s.subsidy.conditionNote}</p>
    </div>
  ) : (
    <p class="pr-cond">{s.subsidy.conditionNote}</p>
  )}
  {!s.verified && s.verifyNote && <p class="pr-verify">{s.verifyNote}</p>}
</div>
