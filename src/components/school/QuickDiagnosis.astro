---
/** タップ式かんたん診断（showcase型・3問タップ→即おすすめ表示）。
 *  サイドバー等に埋め込む軽量版。M-1: enumのみ・textContent/DOM生成はcreateElementのみ。 */
import { SCHOOLS, SEGMENTS, editorialScore, GENRE } from '../../lib/schools';
const def = SEGMENTS.find((s) => s.slug === 'default')!;
const data = SCHOOLS.filter((s) => s.enrollable).map((s) => ({
  id: s.id, name: s.shortName, type: s.type,
  purpose: s.tags.purpose, format: s.tags.format,
  monthly: s.budget.monthly, total: s.budget.total,
  subsidy: s.subsidy.type, score: editorialScore(s, def),
  cta: s.cta.url, ctaLabel: s.cta.primary,
  rel: s.affiliate ? 'sponsored nofollow noopener' : 'noopener',
  path: `${GENRE.basePath}/${s.id}`,
}));
---
<quick-diag class="qdiag" data-schools={JSON.stringify(data)}>
  <div class="qd-q">Q1. 目的は？</div>
  <div class="qd-opts" data-axis="p">
    <button type="button" class="qd-opt" data-v="tenshoku" aria-pressed="false">AI転職</button>
    <button type="button" class="qd-opt" data-v="fukugyo" aria-pressed="false">仕事で使う</button>
    <button type="button" class="qd-opt" data-v="reskilling" aria-pressed="false">学び直し</button>
  </div>
  <div class="qd-q">Q2. 予算は？</div>
  <div class="qd-opts" data-axis="b">
    <button type="button" class="qd-opt" data-v="m2" aria-pressed="false">月1〜2万円台</button>
    <button type="button" class="qd-opt" data-v="t5" aria-pressed="false">総額5万円まで</button>
    <button type="button" class="qd-opt" data-v="sub" aria-pressed="false">給付金を使いたい</button>
  </div>
  <div class="qd-q">Q3. 学び方は？</div>
  <div class="qd-opts" data-axis="f">
    <button type="button" class="qd-opt" data-v="subscription" aria-pressed="false">動画で自分のペース</button>
    <button type="button" class="qd-opt" data-v="banso" aria-pressed="false">講師の伴走つき</button>
    <button type="button" class="qd-opt" data-v="taimen" aria-pressed="false">教室で対面</button>
  </div>
  <div class="qd-result" aria-live="polite"></div>
</quick-diag>

<script>
  const OK = {
    p: ['tenshoku', 'fukugyo', 'reskilling'],
    b: ['m2', 't5', 'sub'],
    f: ['subscription', 'banso', 'taimen'],
  };
  class QuickDiag extends HTMLElement {
    st: Record<string, string> = {};
    schools: any[] = [];
    connectedCallback() {
      try { this.schools = JSON.parse(this.dataset.schools || '[]'); } catch { this.schools = []; }
      this.querySelectorAll<HTMLElement>('.qd-opts').forEach((g) => {
        const axis = g.dataset.axis!;
        g.querySelectorAll<HTMLButtonElement>('button.qd-opt').forEach((b) => {
          b.addEventListener('click', () => {
            const v = b.dataset.v!;
            if (!(OK as any)[axis]?.includes(v)) return;
            const on = this.st[axis] === v;
            this.st[axis] = on ? '' : v;
            g.querySelectorAll('button').forEach((x) => x.setAttribute('aria-pressed', String(x === b && !on)));
            this.show();
          });
        });
      });
    }
    show() {
      const { p, b, f } = this.st;
      const box = this.querySelector('.qd-result')!;
      box.textContent = '';
      if (!p && !b && !f) return;
      const cond = (s: any) => {
        const checks: boolean[] = [];
        if (p) checks.push(s.purpose.includes(p));
        if (f) checks.push(s.format.includes(f));
        if (b === 'm2') checks.push(s.monthly != null && s.monthly <= 29999);
        if (b === 't5') checks.push(s.total != null && s.total <= 50000);
        if (b === 'sub') checks.push(s.subsidy !== 'none');
        return { total: checks.length, ok: checks.filter(Boolean).length };
      };
      const scored = this.schools
        .map((s) => ({ s, ...cond(s) }))
        .sort((a, c) => c.ok - a.ok || c.s.score - a.s.score);
      const full = scored.filter((x) => x.ok === x.total);
      // 完全一致がなくても行き止まりにせず、最も条件に近い1校を差分つきで正直に提示
      const top = (full[0] ?? scored[0]).s;
      const near = full.length === 0;
      if (near && scored[0].ok === 0) {
        box.textContent = '条件に合うスクールが見つかりませんでした。条件を1つ外してみてください。';
        return;
      }
      const div = document.createElement('div');
      div.className = 'qd-hit';
      if (near) {
        const note = document.createElement('div');
        note.textContent = `全条件一致はありませんでした。いちばん近いのは（${scored[0].ok}/${scored[0].total}条件に合致）`;
        note.style.fontSize = '.78rem';
        div.append(note);
      }
      const b1 = document.createElement('b'); b1.textContent = top.name;
      const sp = document.createElement('div');
      sp.textContent = near
        ? `${top.type}・編集部評価 ${top.score.toFixed(1)}`
        : `${top.type}・編集部評価 ${top.score.toFixed(1)}（${full.length}校が該当）`;
      sp.style.fontSize = '.78rem'; sp.style.color = 'var(--text-dim)';
      // 診断→CTA直結（CRO監査H-2）: 主=無料相談（外部）、副=詳細レビュー（内部）
      const row = document.createElement('div');
      row.className = 'qd-actions';
      const cta = document.createElement('a');
      cta.href = top.cta; cta.rel = top.rel; cta.target = '_blank';
      cta.className = 'aff-btn qd-cta'; cta.textContent = top.ctaLabel;
      const a = document.createElement('a'); a.href = top.path; a.textContent = '詳細をみる ›';
      a.style.fontWeight = '700'; a.style.fontSize = '.85rem';
      row.append(cta, a);
      div.append(b1, sp, row);
      box.append(div);
    }
  }
  if (!customElements.get('quick-diag')) customElements.define('quick-diag', QuickDiag);
</script>
