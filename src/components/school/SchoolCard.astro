---
/** ランキングカード（prodig型の全要素）。JSゼロ（開閉はdetails/summary）。
 *  rel属性はaffiliateフラグから自動決定（H-1: PR化はデータ差替のみで原子的に）。 */
import type { SchoolT, SegmentT } from '../../lib/schools';
import RankBadge from './RankBadge.astro';
import Stars from './Stars.astro';
import PriceTable from './PriceTable.astro';
import Voices from './Voices.astro';
import EditorNote from './EditorNote.astro';
import { GENRE } from '../../lib/schools';
import fs from 'node:fs';

interface Props { school: SchoolT; rank: number; score: number; segment: SegmentT }
const { school: s, rank, score, segment } = Astro.props;
const rel = s.affiliate ? 'sponsored nofollow noopener' : 'noopener';
const segNote = segment.notes[s.id];
// 編集部作成イラスト（画像スプリント生成分・未生成校はスキップ）
const eyecatch = fs.existsSync(`public/img/genres/ai-school/${s.id}.jpg`)
  ? `/img/genres/ai-school/${s.id}.jpg`
  : null;
---
<article
  class={`school-card${rank === 1 ? ' top' : ''}`}
  id={s.id}
  data-purpose={s.tags.purpose.join(' ')}
  data-format={s.tags.format.join(' ')}
  data-kodawari={s.tags.kodawari.join(' ')}
  data-monthly={s.budget.monthly ?? ''}
  data-total={s.budget.total ?? ''}
  data-subsidy={s.subsidy.type}
  data-score={score}
>
  <div class="school-head">
    <RankBadge rank={rank} />
    <div>
      <div class="sc-name"><a href={`${GENRE.basePath}/${s.id}`}>{s.name}</a></div>
      <Stars score={score} />
    </div>
    <div class="sc-badges">
      <span class="sc-badge">{s.type}</span>
      {s.badges.map((b) => <span class="sc-badge warn">{b}</span>)}
    </div>
  </div>
  <div class="school-body">
    {eyecatch && (
      <img class="sc-eyecatch" src={eyecatch} alt={`${s.shortName}の学習イメージ（編集部作成イラスト）`} width="1200" height="568" loading="lazy" />
    )}
    {segNote && <p class="sc-segnote">{segNote}</p>}
    <ul class="sc-points">
      {s.points.map((p) => <li>{p}</li>)}
    </ul>
    {s.detail.toolsAndModels && (
      <div class="sc-models">
        <b>使用ツール・対応モデル</b>
        <ul>{s.detail.toolsAndModels.map((m) => <li>{m}</li>)}</ul>
      </div>
    )}
    <PriceTable school={s} />
    <div class="sc-reason"><b>編集部の評価</b>: {s.reason}</div>
    <div class="box-warn"><div class="box-title">申し込む前の注意</div>{s.caution}</div>
    <EditorNote text={s.editorNote} />
    <Voices school={s} />
    <div class="sc-cta">
      <a class="aff-btn" href={s.cta.url} rel={rel} target="_blank">{s.cta.primary}</a>
      <a class="ghost" href={s.cta.url} rel={rel} target="_blank">公式サイトをみる</a>
    </div>
    <p class="cta-note" style="text-align:center;">{s.cta.note} ／ <a href={`${GENRE.basePath}/${s.id}`}>詳細レビューを読む</a></p>
  </div>
</article>
