---
/** スマホ追従バー（競合比較メディアが持たない差別化・UX調査P0）。
 *  アンカー先がそのページに存在しない場合はメインLPへ送る（詳細ページ・広告LP対策）。 */
import { GENRE } from '../../lib/schools';
---
<sticky-bar class="stickybar" data-base={GENRE.basePath} aria-label="ページ内ナビゲーション">
  <a href="#top">TOP</a>
  <a href="#shindan">診断</a>
  <a href="#hikaku">比較表</a>
  <a href="#ranking">ランキング</a>
</sticky-bar>
<script>
  class StickyBar extends HTMLElement {
    connectedCallback() {
      // このページに実在しないアンカーはメインLPの同セクションへフォールバック
      const base = this.dataset.base || '';
      this.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
        const id = (a.getAttribute('href') || '').slice(1);
        if (id && !document.getElementById(id)) a.setAttribute('href', `${base}#${id}`);
      });
      const onScroll = () => this.classList.toggle('is-on', window.scrollY > 480);
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  }
  if (!customElements.get('sticky-bar')) customElements.define('sticky-bar', StickyBar);
</script>
