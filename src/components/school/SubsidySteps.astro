---
/** 給付金が戻るまでの流れの図解（HTML/CSS製・視覚導入2026-07-08）。
 *  画像生成では日本語が崩れるため、正確さが要る図解はコードで描く方針。
 *  「割引ではなく条件達成後の事後支給」を視覚で理解させる（優良誤認の予防にも効く）。 */
const STEPS = [
  { n: '1', t: '無料相談で対象確認', d: '受給資格と対象コースをスクールに確認' },
  { n: '2', t: 'いったん満額を支払い受講', d: '給付金は割引ではないため先に全額負担' },
  { n: '3', t: '修了・転職などの条件達成', d: '制度ごとの条件をすべて満たす' },
  { n: '4', t: '達成後に支給される', d: '最大70〜80%が事後キャッシュバック' },
];
---
<div class="seg-steps" aria-label="給付金が戻るまでの流れ">
  <div class="ss-head">給付金が戻るまでの流れ</div>
  <ol class="ss-row">
    {STEPS.map((s) => (
      <li class="ss-item">
        <span class="ss-num">{s.n}</span>
        <b>{s.t}</b>
        <span class="ss-desc">{s.d}</span>
      </li>
    ))}
  </ol>
</div>
