---
/** 受講者の声（カルーセル版・CRO監査H-4）。
 *  実在の声のみ・出典1:1（H-5）。3件以上はCSS Scroll Snapのカルーセル、
 *  2件以下は従来グリッド。JS無効時はカルーセルも折返しグリッドに戻る
 *  （:not(:defined)フォールバック）。アバターは属性ベースの円形イニシャル
 *  （画像スプリント後にイラストアバターへ差し替え可能な構造）。 */
import type { SchoolT } from '../../lib/schools';
interface Props { school: SchoolT }
const { school: s } = Astro.props;
const AV_COLORS = ['#1C6B54', '#C39433', '#B87C48', '#134C3B', '#8a6d3b'];
/** 「40代・営業職」→「営」のように、年代数字ではなく職業・立場の頭文字を使う
 *  （数字だと順位バッジと紛らわしい）。 */
const initial = (attr: string) => {
  const cleaned = attr.replace(/[（(].*$/, '');
  const seg = cleaned.includes('・') ? cleaned.split('・').find((x) => !/^\d/.test(x)) ?? cleaned : cleaned;
  const m = seg.match(/[぀-ヿ㐀-鿿A-Za-z]/u);
  return m ? m[0] : '声';
};
/** 鮮度優先: 新しい年の声から順に表示（ここ1年以内の声が最重要という編集方針） */
const voices = [...s.voices].sort(
  (a, b) => (parseInt(String(b.year), 10) || 0) - (parseInt(String(a.year), 10) || 0)
);
/** 出典リンクはテキストフラグメント付き＝クリックで引用該当箇所へ直ジャンプ（読者が一瞬で根拠確認できる）。
 *  rel=nofollowで他サイトへ評価は渡さない。 */
const jumpUrl = (v: { url: string; quote: string }) => {
  const frag = v.quote.split(/[…〔（(「』」]/)[0].trim();
  return frag.length >= 8 ? `${v.url}#:~:text=${encodeURIComponent(frag.slice(0, 30))}` : v.url;
};
const useCarousel = voices.length >= 3;
---
{voices.length > 0 ? (
  useCarousel ? (
    <voice-carousel class="sc-voices vo-carousel">
      <div class="voices-head">受講者・検討者の声<span class="voices-count">実在の{voices.length}件</span></div>
      <div class="vo-viewport">
        <div class="vo-track" role="list">
          {voices.map((v, i) => (
            <div class="vo-card" role="listitem">
              <div class="vo-top">
                <span class="vo-av" style={`background:${AV_COLORS[i % AV_COLORS.length]}`}>{initial(v.attr)}</span>
                <span class="vo-attr">{v.attr}</span>
              </div>
              <p class="vo-text">{v.quote}</p>
              <div class="vo-src">{v.year}・<a href={jumpUrl(v)} rel="nofollow noopener" target="_blank">{v.media}</a></div>
            </div>
          ))}
        </div>
      </div>
      <div class="vo-ctrl">
        <button type="button" class="vo-prev" aria-label="前の口コミ">‹</button>
        <div class="vo-dots" aria-hidden="true"></div>
        <button type="button" class="vo-next" aria-label="次の口コミ">›</button>
      </div>
    </voice-carousel>
  ) : (
    <div class="sc-voices">
      <div class="voices-head">受講者・検討者の声<span class="voices-count">実在の{voices.length}件</span></div>
      <div class="vo-grid">
        {voices.map((v, i) => (
          <div class="vo-card">
            <div class="vo-top">
              <span class="vo-av" style={`background:${AV_COLORS[i % AV_COLORS.length]}`}>{initial(v.attr)}</span>
              <span class="vo-attr">{v.attr}</span>
            </div>
            <p class="vo-text">{v.quote}</p>
            <div class="vo-src">{v.year}・<a href={jumpUrl(v)} rel="nofollow noopener" target="_blank">{v.media}</a></div>
          </div>
        ))}
      </div>
    </div>
  )
) : (
  s.voicesNote && <p class="voices-none">{s.voicesNote}</p>
)}

<script>
  /** CSS Scroll Snapに乗せるだけの薄いカルーセル。DOM生成はcreateElement/textContentのみ（M-1）。 */
  class VoiceCarousel extends HTMLElement {
    track!: HTMLElement;
    cards: HTMLElement[] = [];
    prev!: HTMLButtonElement;
    next!: HTMLButtonElement;
    dots!: HTMLElement;
    connectedCallback() {
      this.track = this.querySelector('.vo-track')!;
      this.cards = [...this.querySelectorAll<HTMLElement>('.vo-card')];
      if (this.cards.length < 2) { this.querySelector('.vo-ctrl')?.remove(); return; }
      this.prev = this.querySelector('.vo-prev')!;
      this.next = this.querySelector('.vo-next')!;
      this.dots = this.querySelector('.vo-dots')!;
      this.cards.forEach((_, i) => {
        const d = document.createElement('i');
        d.addEventListener('click', () => this.go(i));
        this.dots.appendChild(d);
      });
      this.prev.addEventListener('click', () => this.go(this.index() - 1));
      this.next.addEventListener('click', () => this.go(this.index() + 1));
      this.track.addEventListener('scroll', () => this.sync(), { passive: true });
      this.sync();
    }
    index(): number {
      // スクロール終端では「最終カードが右端に張り付く」ため位置÷カード幅では最終indexに届かない。
      // 終端は明示的に最終indexへクランプし、それ以外はoffsetLeftが最も近いカードを現在地とする。
      const maxX = this.track.scrollWidth - this.track.clientWidth;
      const x = this.track.scrollLeft;
      if (x >= maxX - 4) return this.cards.length - 1;
      const base = this.cards[0].offsetLeft;
      let best = 0, bd = Infinity;
      this.cards.forEach((c, i) => {
        const d = Math.abs((c.offsetLeft - base) - x);
        if (d < bd) { bd = d; best = i; }
      });
      return best;
    }
    go(i: number) {
      const n = Math.max(0, Math.min(i, this.cards.length - 1));
      const left = this.cards[n].offsetLeft - this.cards[0].offsetLeft;
      this.track.scrollTo({ left, behavior: 'smooth' });
    }
    sync() {
      const i = this.index();
      [...this.dots.children].forEach((d, j) => d.classList.toggle('on', j === i));
      this.prev.disabled = i <= 0;
      this.next.disabled = i >= this.cards.length - 1;
    }
  }
  if (!customElements.get('voice-carousel')) customElements.define('voice-carousel', VoiceCarousel);
</script>
