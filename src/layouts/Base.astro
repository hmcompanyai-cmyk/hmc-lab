---
import { SITE } from '../config/site';
import GENRE from '../data/genres/ai-school/genre.json';
import '@fontsource/noto-sans-jp/900.css';
import '@fontsource/zen-kaku-gothic-new/400.css';
import '@fontsource/zen-kaku-gothic-new/700.css';
import '@fontsource/zen-kaku-gothic-new/900.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/800.css';
import '@fontsource/zen-maru-gothic/900.css';
import DiagnosisWizard from '../components/school/DiagnosisWizard.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  jsonLd?: object | null;
  ogImage?: string | null;
  noindex?: boolean;
  wide?: boolean;
}
const {
  title, description = SITE.description, ogType = 'website',
  jsonLd = null, ogImage = null,
  // 既定は「サイト公開フラグに従う」: genre.indexable:false の間は全ページ noindex。
  // 公開時は genre.json の indexable を true にするだけで全ページ・sitemapが一斉に追従する
  // （blog/about/privacy だけ index可能になる部分漏れが起きていた技術SEO監査B-1の修正）
  noindex = !GENRE.indexable, wide = false,
} = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : `${SITE.title} | ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
// SNSシェア時に画像なしカードにならないよう、未指定ページはサイト既定のOG画像を使う（SEO監査H-4）
const ogImg = ogImage ?? '/img/og-default.png';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="256x256" href="/favicon-256.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={SITE.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:image" content={new URL(ogImg, Astro.site)} />
    <meta name="twitter:image" content={new URL(ogImg, Astro.site)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <!-- Google Analytics 4（外部送信の詳細は /info#privacy に明記） -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KN25EL67PY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-KN25EL67PY');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'AI番付',
      alternateName: 'HMCompany',
      url: Astro.site?.toString(),
      logo: new URL('/apple-touch-icon.png', Astro.site).toString(),
      description: SITE.description,
    })} />
  </head>
  <body>
    <div class="utilbar">
      <div class="utilbar-in">
        <span>生成AIスクールとAIツールを、同じ物差しで比較する編集部メディア</span>
        <span class="utilbar-links">
          <a href="/info#company">運営者情報</a><a href="/info#ranking-basis">評価方法</a><a href="/info#company">お問い合わせ</a>
        </span>
      </div>
    </div>
    <header class="site">
      <div class="site-in">
        <a href="/" class="logo"><span>AI</span>番付</a>
        <nav>
          <a href="/#ranking">ランキング</a>
          <a href="/ai-school/tenshoku">目的別で探す</a>
          <a href="/ai-school/kyufu">給付金対象</a>
          <a href="/ai-school">スクール比較</a>
          <a href="/blog">編集部コラム</a>
        </nav>
        <a href="/#shindan" class="aff-btn head-cta">無料診断</a>
      </div>
    </header>
    <main class={wide ? 'wrap wide' : 'wrap'}>
      <slot />
    </main>
    <footer class="site">
      <div class="foot-in">
        <div>
          <div class="logo"><span>AI</span>番付</div>
          <p>{SITE.description}</p>
          <p>運営: 社員全員AIの会社 HMCompany（人間の運営責任者が公開前に確認）</p>
        </div>
        <div>
          <b>目的別で探す</b>
          <a href="/ai-school/tenshoku">AI転職</a>
          <a href="/ai-school/fukugyo">副業・業務活用</a>
          <a href="/ai-school/reskilling">リスキリング</a>
          <a href="/ai-school/kyufu">給付金対象</a>
        </div>
        <div>
          <b>コンテンツ</b>
          <a href="/ai-school">スクール比較ランキング</a>
          <a href="/blog">編集部コラム（AIツールレビュー）</a>
          <a href="https://note.com/hmai_company">会社の実録連載（note）</a>
        </div>
        <div>
          <b>サイト情報</b>
          <a href="/info#company">運営者情報</a>
          <a href="/info#ranking-basis">ランキングの評価方法</a>
          <a href="/info#rule">免責事項</a>
          <a href="/info#privacy">プライバシーポリシー</a>
        </div>
      </div>
      <p class="foot-copy">© 2026 HMCompany. 当サイトはアフィリエイトプログラムに参加しています。</p>
    </footer>
    <!-- 無料診断ウィザード（全ページ共通・2026-07-11: どのページ/タイミングでも同じ体験） -->
    <div class="diag-modal" id="diag-modal" hidden>
      <div class="dm-backdrop" data-close></div>
      <div class="dm-panel" role="dialog" aria-modal="true" aria-label="無料診断">
        <button type="button" class="dm-close" data-close aria-label="閉じる">×</button>
        <div class="dm-head">30秒で、あなたに合うAIスクール診断</div>
        <DiagnosisWizard />
      </div>
    </div>
    <script>
      // 無料診断: モバイル=常にウィザードモーダル / PC=ページ内に診断があればスクロール・なければモーダル
      (() => {
        const modal = document.getElementById('diag-modal');
        if (!modal) return;
        const isMobile = () => window.matchMedia('(max-width: 760px)').matches;
        const open = () => { modal.hidden = false; document.body.style.overflow = 'hidden'; };
        const close = () => { modal.hidden = true; document.body.style.overflow = ''; };
        document.addEventListener('click', (e) => {
          const a = (e.target as HTMLElement).closest('a[href*="#shindan"]') as HTMLAnchorElement | null;
          if (!a) return;
          const local = document.getElementById('shindan');
          if (isMobile() || !local) { e.preventDefault(); open(); }
          // PCでページ内に診断がある場合は従来どおりアンカースクロール
        });
        modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.hidden) close(); });
      })();
    </script>
    <script>
      // ヘッダー自動隠し: 下スクロール中は隠して本文を全画面に、上スクロールで即復帰（UX指摘2026-07-11）
      let hhLast = 0;
      let hhTick = false;
      const hhBars = () => [document.querySelector('header.site'), document.querySelector('.lp-nav')].filter(Boolean);
      window.addEventListener('scroll', () => {
        if (hhTick) return;
        hhTick = true;
        requestAnimationFrame(() => {
          const y = window.scrollY;
          const down = y > hhLast && y > 160;
          hhBars().forEach((el) => el && el.classList.toggle('hh-hide', down));
          hhLast = y;
          hhTick = false;
        });
      }, { passive: true });

      // CTAシマー: 画面に入るたびキラッ（reduced-motionはCSS側で無効化）
      const io = new IntersectionObserver((es) => {
        es.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.remove('shine');
            void (e.target as HTMLElement).offsetWidth;
            e.target.classList.add('shine');
          }
        });
      }, { threshold: 0.6 });
      document.querySelectorAll('.aff-btn').forEach((b) => io.observe(b));

      // CTAクリック計測（GA4キーイベントの元データ。外部=cta_out / 内部=cta_in）
      document.addEventListener('click', (ev) => {
        const a = (ev.target as HTMLElement).closest('a.aff-btn, a.dw-cta') as HTMLAnchorElement | null;
        if (!a || typeof (window as any).gtag !== 'function') return;
        const external = a.host !== location.host;
        (window as any).gtag('event', external ? 'cta_out' : 'cta_in', {
          cta_label: (a.textContent || '').trim().slice(0, 40),
          cta_url: a.href.slice(0, 100),
        });
      });
    </script>
  </body>
</html>
