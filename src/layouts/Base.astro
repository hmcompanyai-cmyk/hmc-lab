---
import { SITE } from '../config/site';
import '@fontsource/noto-sans-jp/900.css';
import '@fontsource/zen-kaku-gothic-new/400.css';
import '@fontsource/zen-kaku-gothic-new/700.css';
import '@fontsource/zen-kaku-gothic-new/900.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/800.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  jsonLd?: object | null;
  ogImage?: string | null;
  noindex?: boolean;
  wide?: boolean;
}
const {
  title, description = SITE.description, ogType = 'website',
  jsonLd = null, ogImage = null, noindex = false, wide = false,
} = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : `${SITE.title} | ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={SITE.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}
    {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <div class="utilbar">
      <div class="utilbar-in">
        <span>生成AIスクールとAIツールを、同じ物差しで比較する編集部メディア</span>
        <span class="utilbar-links">
          <a href="/info#company">運営者情報</a><a href="/info#ranking-basis">評価方法</a><a href="/info#company">お問い合わせ</a>
        </span>
      </div>
    </div>
    <header class="site">
      <div class="site-in">
        <a href="/" class="logo">くらべ<span>AI</span></a>
        <nav>
          <a href="/#ranking">ランキング</a>
          <a href="/ai-school/tenshoku">目的別で探す</a>
          <a href="/ai-school/kyufu">給付金対象</a>
          <a href="/ai-school">スクール比較</a>
          <a href="/blog">記事</a>
        </nav>
        <a href="/#shindan" class="aff-btn head-cta">無料診断</a>
      </div>
    </header>
    <main class={wide ? 'wrap wide' : 'wrap'}>
      <slot />
    </main>
    <footer class="site">
      <div class="foot-in">
        <div>
          <div class="logo">くらべ<span>AI</span></div>
          <p>{SITE.description}</p>
          <p>運営: 社員全員AIの会社 HMCompany（人間の編集長が監修）</p>
        </div>
        <div>
          <b>目的別で探す</b>
          <a href="/ai-school/tenshoku">AI転職</a>
          <a href="/ai-school/fukugyo">副業・業務活用</a>
          <a href="/ai-school/reskilling">リスキリング</a>
          <a href="/ai-school/kyufu">給付金対象</a>
        </div>
        <div>
          <b>コンテンツ</b>
          <a href="/ai-school">スクール比較ランキング</a>
          <a href="/blog">AIツールレビュー記事</a>
          <a href="https://note.com/hmai_company">会社の実録連載（note）</a>
        </div>
        <div>
          <b>サイト情報</b>
          <a href="/info#company">運営者情報</a>
          <a href="/info#ranking-basis">ランキングの評価方法</a>
          <a href="/info#rule">免責事項</a>
          <a href="/info#privacy">プライバシーポリシー</a>
        </div>
      </div>
      <p class="foot-copy">© 2026 HMCompany. 当サイトはアフィリエイトプログラムに参加しています。</p>
    </footer>
    <script>
      // CTAシマー: 画面に入るたびキラッ（reduced-motionはCSS側で無効化）
      const io = new IntersectionObserver((es) => {
        es.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.remove('shine');
            void (e.target as HTMLElement).offsetWidth;
            e.target.classList.add('shine');
          }
        });
      }, { threshold: 0.6 });
      document.querySelectorAll('.aff-btn').forEach((b) => io.observe(b));
    </script>
  </body>
</html>
