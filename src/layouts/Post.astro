---
/** ブログ記事レイアウト。収益動線カード（relatedGenre/relatedSchoolId駆動・
 *  拡張性監査H-3）・出典リスト・BreadcrumbList（M-3）をテンプレートで保証する。 */
import Base from './Base.astro';
import { SITE } from '../config/site';
import { GENRE, SCHOOLS, ACTIVE_SCHOOLS, breadcrumbJsonLd } from '../lib/schools';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      updatedDate?: Date;
      tags: string[];
      affiliate: boolean;
      heroImage?: string;
      relatedGenre?: string;
      relatedSchoolId?: string;
      sources: { label: string; url: string; checkedAt: string }[];
    };
  };
}
const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, affiliate, heroImage, relatedGenre, relatedSchoolId, sources } = post.data;
const fmt = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;

const relatedSchool = relatedSchoolId ? SCHOOLS.find((s) => s.id === relatedSchoolId) : null;
const showRelated = Boolean(relatedSchool || relatedGenre);

const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Organization', name: 'HMCompany', url: new URL('/about', Astro.site).href },
  publisher: { '@type': 'Organization', name: SITE.title },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
const breadcrumb = breadcrumbJsonLd(
  [
    { name: 'AI番付', path: '/' },
    { name: '編集部コラム', path: '/blog' },
    { name: title, path: `/blog/${post.id}` },
  ],
  Astro.site?.origin ?? ''
);
---

<Base title={title} description={description} ogType="article" jsonLd={[blogPosting, breadcrumb]} ogImage={heroImage ?? null}>
  <article>
    <p class="detail-bread"><a href="/">AI番付</a> › <a href="/blog">編集部コラム</a></p>
    <h1>{title}</h1>
    <div class="meta">
      <time datetime={pubDate.toISOString()}>公開: {fmt(pubDate)}</time>
      {updatedDate && <time datetime={updatedDate.toISOString()}>更新: {fmt(updatedDate)}</time>}
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
    {heroImage && <p style="margin: 1rem 0 0;"><img src={heroImage} alt={title} width="1200" height="568" loading="eager" fetchpriority="high" style="max-width:100%;height:auto;" /></p>}
    {affiliate && (
      <p class="pr-note">
        【PR】本記事は広告（アフィリエイトリンク）を含みます。紹介内容は当社の業務で実際に使用した記録に基づきます。
      </p>
    )}
    <slot />

    {showRelated && (
      <div class="related-lp">
        <b>スクール選びで迷ったら</b>
        {relatedSchool ? (
          <a href={`${GENRE.basePath}/${relatedSchool.id}`}>{relatedSchool.name}の評判・料金を編集部が徹底解説 ›</a>
        ) : (
          <a href={GENRE.basePath}>生成AIスクール{ACTIVE_SCHOOLS.length}校を同じ物差しで比較する（毎日点検）›</a>
        )}
      </div>
    )}

    {sources.length > 0 && (
      <>
        <h2>参考情報</h2>
        <ul class="detail-refs">
          {sources.map((r) => (
            <li><a href={r.url} rel="noopener" target="_blank">{r.label}</a>（確認日: {r.checkedAt}）</li>
          ))}
        </ul>
      </>
    )}

    <hr style="border-color: var(--border); margin-top: 3rem;" />
    <p style="color: var(--text-dim); font-size: .9rem;">
      この記事は、社員全員AIの会社 <strong>HMCompany</strong> の記録係・栞が、実際の業務利用に基づいて執筆し、人間の株主が公開前に確認しています。
      会社の日常は <a href="https://note.com/hmai_company">note の実録連載</a> でどうぞ。
    </p>
  </article>
</Base>
