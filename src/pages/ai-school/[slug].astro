---
/** サブLP4本（kind:segment）とスクール個別ページ7本（kind:school）の統合ルート。
 *  slug衝突はlib/schools.tsのビルド時assertで防止済み（architect GO条件1）。 */
import LpLayout from '../../layouts/LpLayout.astro';
import SegmentSection from '../../components/school/SegmentSection.astro';
import PrLabel from '../../components/school/PrLabel.astro';
import PriceTable from '../../components/school/PriceTable.astro';
import Voices from '../../components/school/Voices.astro';
import EditorNote from '../../components/school/EditorNote.astro';
import Stars from '../../components/school/Stars.astro';
import {
  SEGMENTS, SCHOOLS, segmentBySlug, itemListJsonLd, breadcrumbJsonLd,
  rankedSchools, GENRE,
} from '../../lib/schools';

export function getStaticPaths() {
  const segs = SEGMENTS.filter((s) => s.slug !== 'default')
    .map((s) => ({ params: { slug: s.slug }, props: { kind: 'segment' as const } }));
  const schools = SCHOOLS.map((s) => ({ params: { slug: s.id }, props: { kind: 'school' as const } }));
  return [...segs, ...schools];
}

const { slug } = Astro.params;
const { kind } = Astro.props;
const site = Astro.site?.origin ?? '';
const noindex = !GENRE.indexable;

let title = '', description = '', jsonLd: object | null = null;
let seg = null, school = null, defRank = null;
let altSchools: ReturnType<typeof rankedSchools> = [];
let rankedDef: ReturnType<typeof rankedSchools> = [];
let altSeg: { slug: string; label: string } | null = null;

if (kind === 'segment') {
  seg = segmentBySlug(slug!)!;
  title = seg.title;
  description = seg.description;
  jsonLd = itemListJsonLd(seg, site);
} else {
  school = SCHOOLS.find((s) => s.id === slug)!;
  const def = segmentBySlug('default')!;
  rankedDef = rankedSchools(def);
  defRank = rankedDef.find((e) => e.school.id === school!.id) ?? null; // 受付停止校はランキング外
  // SEO監査H-6: 同じ目的の次点校2件＋該当セグメントLPへの横リンク（回遊とCV回収）
  altSchools = rankedDef
    .filter((e) => e.school.id !== school!.id && e.school.tags.purpose.some((p) => school!.tags.purpose.includes(p)))
    .slice(0, 2);
  const segSlug = school.subsidy.type !== 'none' ? 'kyufu' : school.tags.purpose[0];
  const segMatch = SEGMENTS.find((x) => x.slug === segSlug);
  altSeg = segMatch ? { slug: segMatch.slug, label: segMatch.label } : null;
  title = `${school.name}の評判・料金を徹底解説【${GENRE.updatedDate.slice(0, 7).replace('-', '年')}月】`;
  description = school.detail.lead.slice(0, 110);
  jsonLd = breadcrumbJsonLd(
    [
      { name: 'くらべAI', path: '/' },
      { name: '生成AIスクール比較', path: GENRE.basePath },
      { name: school.shortName, path: `${GENRE.basePath}/${school.id}` },
    ],
    site
  );
}
const rel = school?.affiliate ? 'sponsored nofollow noopener' : 'noopener';
// 個別ページの追従CTAは当該校の無料相談へ直結（CRO監査H-1）
const stickyCta = school ? { href: school.cta.url, label: '無料相談', rel } : undefined;
// アイキャッチ（画像スプリント生成分。未生成校はビルド時のfs存在チェックでスキップ）
import fs from 'node:fs';
const eyecatch =
  school && fs.existsSync(`public/img/genres/ai-school/${school.id}.jpg`)
    ? `/img/genres/ai-school/${school.id}.jpg`
    : null;
---
<LpLayout title={title} description={description} noindex={noindex} jsonLd={jsonLd} stickyCta={stickyCta} ogImage={eyecatch}>
  {kind === 'segment' && seg && <SegmentSection segment={seg} />}

  {kind === 'school' && school && (
    <article>
      <p class="detail-bread">
        <a href={GENRE.basePath}>生成AIスクール比較</a> › {school.shortName}
      </p>
      <h1>{school.name}の評判・料金・向いている人</h1>
      {/* 法務監査C-1: affiliate:true化時にPR表記が詳細ページで欠落しないよう必ず描画 */}
      <PrLabel />
      {eyecatch && (
        <p class="detail-eyecatch"><img src={eyecatch} alt={`${school.shortName}の学習イメージ（編集部作成イラスト）`} width="1200" height="568" loading="eager" /></p>
      )}
      <div class="meta">
        {defRank ? (
          <>
            <span>総合{defRank.rank}位 / {rankedDef.length}校</span>
            <Stars score={defRank.score} />
          </>
        ) : (
          <span>ランキング対象外（新規受付停止中）</span>
        )}
        <span>確認日: {GENRE.checkedDate}</span>
      </div>
      {!school.enrollable && (
        <div class="box-warn"><div class="box-title">新規受付停止中</div>
          このスクールは現在、公式サイトで新規申込を停止しています（{GENRE.checkedDate}確認）。再開までランキング・比較の対象から外しています。掲載中の料金・内容は停止前の情報です。
        </div>
      )}

      <p>{school.detail.lead}</p>

      <h2>料金と給付金</h2>
      <PriceTable school={school} />

      <div class="cta-wrap">
        <a class="aff-btn" href={school.cta.url} rel={rel} target="_blank">
          {school.enrollable && school.subsidy.type !== 'none' ? '無料相談で給付金の対象か確認する' : school.cta.primary}
        </a>
        <div class="cta-note">{school.cta.note}</div>
      </div>

      <h2>学べること</h2>
      <ul>{school.detail.curriculum.map((c) => <li>{c}</li>)}</ul>

      <h2>良い点・気になる点</h2>
      <ul class="merit">{school.detail.pros.map((p) => <li>{p}</li>)}</ul>
      <ul class="demerit">{school.detail.cons.map((c) => <li>{c}</li>)}</ul>

      <div class="box-warn"><div class="box-title">申し込む前の注意</div>{school.caution}</div>
      <EditorNote text={school.editorNote} />

      <h2>実際の声</h2>
      <Voices school={school} />

      <h2>よくある質問</h2>
      {school.detail.faq.map((f) => (
        <p><b>Q. {f.q}</b><br />{f.a}</p>
      ))}

      <div class="cta-wrap">
        <a class="aff-btn" href={school.cta.url} rel={rel} target="_blank">{school.cta.primary}</a>
        <div class="cta-note">{school.cta.note}</div>
      </div>

      {(altSchools.length > 0 || altSeg) && (
        <>
          <h2>あわせて検討したい</h2>
          <ul>
            {altSchools.map((e) => (
              <li>
                <a href={`${GENRE.basePath}/${e.school.id}`}>{e.school.name}</a> — {e.school.type}（総合{e.rank}位）
              </li>
            ))}
            {altSeg && (
              <li><a href={`${GENRE.basePath}/${altSeg.slug}`}>{altSeg.label}で選ぶランキングをみる ›</a></li>
            )}
          </ul>
        </>
      )}

      <h2>参考情報</h2>
      <ul class="detail-refs">
        {school.detail.references.map((r) => (
          <li><a href={r.url} rel="noopener" target="_blank">{r.label}</a>（確認日: {r.checkedAt}）</li>
        ))}
      </ul>

      <p><a href={GENRE.basePath}>← 生成AIスクール比較ランキングに戻る</a></p>
    </article>
  )}
</LpLayout>
