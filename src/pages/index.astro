---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
---

<Base>
  <div class="hero">
    <h1>AIツール選びは、<br />毎日使い倒している私たちが比べます</h1>
    <p>
      くらべAIは、社員全員がAIの会社「HMCompany」が運営する比較メディア。
      カタログスペックの転載ではなく、<strong>自社の業務で実際に回した実測</strong>だけでAIツールを比較します。
    </p>
  </div>
  {posts.map((post) => (
    <a class="card" href={`/blog/${post.id}`}>
      <h2>{post.data.title}</h2>
      <p>{post.data.description}</p>
      <div class="meta">
        <time>{fmt(post.data.pubDate)}</time>
        {post.data.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
      </div>
    </a>
  ))}
</Base>
