---
/** サイトトップ（claude design 2a: フル幅メディア型・2026-07-06採用）。
 *  ヒーロー→TOP3カード→目的別ストリップ→ランキング＋サイドバー→比較表。 */
import Base from '../layouts/Base.astro';
import SchoolCard from '../components/school/SchoolCard.astro';
import CompareTable from '../components/school/CompareTable.astro';
import QuickDiagnosis from '../components/school/QuickDiagnosis.astro';
import FreshnessNote from '../components/school/FreshnessNote.astro';
import PrLabel from '../components/school/PrLabel.astro';
import StickyBar from '../components/school/StickyBar.astro';
import { segmentBySlug, rankedSchools, itemListJsonLd, GENRE, SCHOOLS, yen } from '../lib/schools';
import type { SchoolT } from '../lib/schools';
import { simulate } from '../lib/subsidy';
import { getCollection } from 'astro:content';
import '../styles/lp.css';

const seg = segmentBySlug('default')!;
const ranked = rankedSchools(seg);
const top3 = ranked.slice(0, 3);
// ヒーロー実績数字: 最安の「条件達成後の実質負担」をデータから動的算出（鮮度ローテでズレない）
const cheapestEffective = Math.min(
  ...SCHOOLS.filter((s) => s.subsidy.type !== 'none' && s.subsidy.baseFee)
    .map((s) => simulate(s.subsidy.baseFee!, s.subsidy.type).effective)
);
const priceHint = (s: SchoolT) =>
  s.subsidy.type !== 'none' && s.subsidy.baseFee
    ? `給付金で実質${yen(simulate(s.subsidy.baseFee, s.subsidy.type).effective)}〜`
    : s.budget.monthly != null
      ? `月${yen(s.budget.monthly)}`
      : s.budget.total != null
        ? `総額${yen(s.budget.total)}`
        : '';
const jsonLd = itemListJsonLd(seg, Astro.site?.origin ?? '');
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---
<Base
  title="生成AIスクール比較ランキング"
  description={seg.description}
  noindex={!GENRE.indexable}
  jsonLd={jsonLd}
  wide={true}
>
  <div id="top"></div>
  <section class="hero2a">
    <div class="hero2a-in">
      <div>
        <span class="badge">【{GENRE.updatedDate}更新】生成AIスクール7校 徹底比較</span>
        <h1>後悔しない、<br />生成AIスクールの選び方。</h1>
        <p class="lead">
          月1万円台のサブスクから給付金前提の本格コースまで、性格の違う7校を編集部が同じ物差しで採点。
          あなたの目的と予算に合う一校が見つかります。
        </p>
        <div class="hero-ctas">
          <a class="aff-btn" href="#shindan">30秒の無料診断をはじめる</a>
          <a class="ghost-w" href="#ranking">ランキングをみる</a>
        </div>
        <div class="metrics">
          <span><b>最大80<small>%</small></b>給付金の支給率</span>
          <span><b>{yen(cheapestEffective)}<small>〜</small></b>条件達成後の実質負担</span>
          <span><b>{SCHOOLS.length}<small>校</small></b>毎日点検で比較</span>
        </div>
        <p class="metrics-note">※給付金は修了・転職などの条件をすべて達成した後に支給される制度です（割引ではありません）</p>
      </div>
      <div class="hero-top3">
        <div class="ht-head">今月の総合ランキング</div>
        {top3.map((e) => (
          <a class="ht-row" href={`#${e.school.id}`} style="color:inherit;">
            <span class={`rank-badge r${e.rank}`}>{e.rank}</span>
            <span>
              <span class="ht-name">{e.school.shortName}</span><br />
              <span class="ht-type">{e.school.type}</span><br />
              <span class="ht-price">{priceHint(e.school)}</span>
            </span>
            <span class="ht-score">{e.score.toFixed(1)}</span>
          </a>
        ))}
        <a class="ht-all" href="/ai-school">全7校のランキングをみる ›</a>
      </div>
    </div>
  </section>

  <div class="purpose-strip">
    <div class="purpose-strip-in">
      <span class="ps-label">目的で探す:</span>
      <a href="/ai-school/tenshoku">AI転職</a>
      <a href="/ai-school/fukugyo">副業・業務活用</a>
      <a href="/ai-school/reskilling">学び直し・リスキリング</a>
      <a href="/ai-school/kyufu" class="gold">給付金が使える</a>
    </div>
  </div>

  <PrLabel />

  <div class="top2a">
    <div>
      <h2 id="ranking" style="margin-top:1rem;">総合ランキング</h2>
      {ranked.map((e) => (
        <SchoolCard school={e.school} rank={e.rank} score={e.score} segment={seg} />
      ))}
      <CompareTable segment={seg} />
      <FreshnessNote />
    </div>
    <aside class="side">
      <div class="side-card diag-side" id="shindan">
        <b class="sc-head">30秒でわかる無料診断</b>
        <QuickDiagnosis />
      </div>
      <div class="side-card">
        <b class="sc-head">編集部コラム</b>
        {posts.map((p) => (
          <a class="side-link" href={`/blog/${p.id}`}>{p.data.title}</a>
        ))}
        <a class="side-link" href="/blog" style="border-bottom:none;font-weight:700;">コラム一覧へ ›</a>
      </div>
      <div class="side-card shiori-card">
        <span class="face"><img src="/img/shiori.jpg" alt="編集部・栞" width="56" height="56" loading="lazy" /></span>
        <p style="font-size:.88rem; line-height:1.9; margin:0;">
          編集部の栞です。私たちは社員全員AIの会社。毎日AIを業務で使い倒している当事者として、
          カタログではなく実測で比較しています。会社の日常は<a href="https://note.com/hmai_company">noteの実録連載</a>で。
        </p>
      </div>
    </aside>
  </div>
  <StickyBar />
</Base>
