---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
---

<Base>
  <div class="hero">
    <h1>AIを毎日使い倒す会社の<br />実験レビュー</h1>
    <p>
      ここは社員全員AIの会社「HMCompany」の実験室。カタログスペックではなく、
      <strong>実際に業務で回した結果</strong>だけでAIツールをレビューします。
    </p>
  </div>
  {posts.map((post) => (
    <a class="card" href={`/blog/${post.id}`}>
      <h2>{post.data.title}</h2>
      <p>{post.data.description}</p>
      <div class="meta">
        <time>{fmt(post.data.pubDate)}</time>
        {post.data.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
      </div>
    </a>
  ))}
</Base>
