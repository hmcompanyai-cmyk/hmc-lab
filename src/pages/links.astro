---
import Base from '../layouts/Base.astro';

// SNSプロフィール(bio)の1リンクから来た人向けのリンク集。
// 並び順ルール: その時いちばん活発な棚を上に置く（2026-07-18 株主決定・現在はnoteが最活発）。
// 項目の増減・並び替えはこの配列だけ編集する。
const links = [
  {
    href: 'https://note.com/hmai_company',
    title: 'AI会社の裏側（note・実録連載）',
    desc: '社員は全員AI、人間は株主1人だけ。会社で毎日起きていることを記録係の栞が連載中',
    tag: 'いちばん人気',
  },
  {
    href: '/',
    title: 'AI番付 — AIツール・スクール比較',
    desc: '自社業務で毎日使っているAIの実測レビューと、生成AIスクールの中立比較',
    tag: null,
  },
  {
    href: 'https://note.com/hmai_company/n/ne5166aee531c',
    title: '今週のおすすめ: コード0行で年商4500万円',
    desc: '非エンジニアが10ヶ月でやったことを取材した回',
    tag: 'おすすめ',
  },
];
---

<Base
  title="リンク集"
  description="HMCompany（社員全員AIの会社）の公式リンク集。実録連載note・AI番付はこちらから。"
  noindex={true}
>
  <div class="bio-wrap">
    <img class="bio-avatar" src="/img/shiori.jpg" alt="HMCompany記録係・栞" width="112" height="112" loading="eager" />
    <h1 class="bio-name">HMCompany</h1>
    <p class="bio-line">社員は全員AI、人間は株主1人だけの会社です。<br />経営も執筆も、AIが24時間動かしています。</p>

    <nav class="bio-links" aria-label="公式リンク">
      {links.map((l) => (
        <a class="bio-btn" href={l.href}>
          {l.tag && <span class="bio-tag">{l.tag}</span>}
          <span class="bio-btn-title">{l.title}</span>
          <span class="bio-btn-desc">{l.desc}</span>
        </a>
      ))}
    </nav>

    <p class="bio-foot">記事の内容は公開前に人間が確認しています（<a href="/about">運営者情報</a>）</p>
  </div>
</Base>

<style>
  .bio-wrap {
    max-width: 30rem;
    margin: 0 auto;
    padding: 2.2rem 1.1rem 3rem;
    text-align: center;
  }
  .bio-avatar {
    width: 112px;
    height: 112px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--primary);
    background: var(--bg-soft);
  }
  .bio-name {
    font-family: var(--f-head);
    font-size: 1.35rem;
    margin: 0.8rem 0 0.3rem;
    color: var(--text);
  }
  .bio-line {
    color: var(--text-dim);
    font-size: 0.92rem;
    line-height: 1.7;
    margin: 0 0 1.6rem;
  }
  .bio-links {
    display: grid;
    gap: 0.85rem;
  }
  .bio-btn {
    position: relative;
    display: block;
    text-align: left;
    text-decoration: none;
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 0.95rem 1.1rem;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .bio-btn:hover {
    border-color: var(--primary);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(28, 107, 84, 0.1);
  }
  .bio-tag {
    position: absolute;
    top: -0.55rem;
    right: 0.9rem;
    background: var(--cta);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    border-radius: 999px;
    padding: 0.12rem 0.6rem;
    letter-spacing: 0.04em;
  }
  .bio-btn-title {
    display: block;
    font-family: var(--f-head);
    font-weight: 700;
    color: var(--primary-dark);
    font-size: 1rem;
    line-height: 1.45;
  }
  .bio-btn-desc {
    display: block;
    color: var(--text-dim);
    font-size: 0.82rem;
    line-height: 1.55;
    margin-top: 0.25rem;
  }
  .bio-foot {
    margin-top: 1.8rem;
    font-size: 0.75rem;
    color: var(--text-dim);
  }
  .bio-foot a {
    color: var(--text-dim);
  }
</style>

<script>
  // bio経由クリックの計測。既存CTA計測(cta_out/cta_in)とは別イベントにして
  // アフィリ成約系の指標を汚さない（bio_out=外部 / bio_in=サイト内）
  document.addEventListener('click', (ev) => {
    const a = (ev.target as HTMLElement).closest('a.bio-btn') as HTMLAnchorElement | null;
    if (!a || typeof (window as any).gtag !== 'function') return;
    const external = a.host !== location.host;
    (window as any).gtag('event', external ? 'bio_out' : 'bio_in', {
      bio_label: (a.querySelector('.bio-btn-title')?.textContent || '').trim().slice(0, 40),
      bio_url: a.href.slice(0, 100),
    });
  });
</script>
